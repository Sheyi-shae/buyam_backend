generator client {
  provider = "prisma-client-js"
  //output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// USER MODEL

model User {
  id               Int       @id @default(autoincrement())
  googleId         String    @unique
  email            String?   @unique
  publicId         String    @unique @default(cuid())
  name             String?
  avatar           String? // Google profile picture
  address          String?
  online           Boolean   @default(false)
  verifiedSeller   Boolean   @default(false)
  lastSeen         DateTime?
  phone            String?
  storeName        String?
  storeDescription String?
  role             String    @default("USER") // USER | ADMIN

  products              Product[]
  likedProducts         ProductLike[]
  conversationsAsBuyer  Conversation[]    @relation("Buyer")
  conversationsAsSeller Conversation[]    @relation("Seller")
  messages              Message[]
  reviews               UserReview[]
  session               Session[]
  reviewLikes           userReviewLikes[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//session
model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// CATEGORY & PRODUCT MODELS
//
model Category {
  id            Int           @id @default(autoincrement())
  name          String
  slug          String        @unique
  description   String?
  avatar        String?
  subcategories SubCategory[]
  products      Product[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([name])
}

model SubCategory {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  avatar      String?
  categoryId  Int
  category    Category  @relation(fields: [categoryId], onDelete: Cascade, references: [id])
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([name])
}

model Product {
  id             Int           @id @default(autoincrement())
  name           String
  price          Float
  avatar         String[]
  description    String
  isPremium      Boolean       @default(false)
  negotiable     Boolean       @default(true)
  isSold         Boolean       @default(false)
  slug           String        @unique
  sellerId       Int
  sellerPublicId String
  state          String
  city           String
  likes          ProductLike[]

  subCategoryId Int
  categoryId    Int
  condition     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subCategory  SubCategory     @relation(fields: [subCategoryId], onDelete: Cascade, references: [id])
  category     Category        @relation(fields: [categoryId], onDelete: Cascade, references: [id])
  seller       User            @relation(fields: [sellerId], onDelete: Cascade, references: [id])
  conversation Conversation[]
  reviews      ProductReview[]
  views        Int             @default(0)

  productViews ProductView[]

  @@index([name])
  @@index([description])
}

model ProductView {
  id        Int      @id @default(autoincrement())
  productId Int
  userId    Int? // optional for non-auth users
  ipAddress String // fallback if not logged in
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

//product likes junction table
model ProductLike {
  id        Int      @id @default(autoincrement())
  productId Int
  userId    Int
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([productId, userId]) // prevents duplicate likes
}

// REVIEWS
//
model ProductReview {
  id        Int      @id @default(autoincrement())
  productId Int
  name      String
  userId    Int
  ratings   Float?   @default(0)
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], onDelete: Cascade, references: [id])
}

model UserReview {
  id        Int                 @id @default(autoincrement())
  userId    Int
  publicId  String
  name      String
  ratings   Float?              @default(0)
  comment   String?
  replies   userReviewReplies[]
  likes     userReviewLikes[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user User @relation(fields: [userId], onDelete: Cascade, references: [id])
}

// review replies
model userReviewReplies {
  id        Int        @id @default(autoincrement())
  reply     String
  reviewId  Int
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  review    UserReview @relation(fields: [reviewId], onDelete: Cascade, references: [id])
}

model userReviewLikes {
  id       Int @id @default(autoincrement())
  reviewId Int
  userId   Int

  review    UserReview @relation(fields: [reviewId], references: [id])
  user      User       @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([reviewId, userId]) // prevents duplicate likes
}

//payment
model Payment {
  id        Int    @id @default(autoincrement())
  reference String @unique
  userId    Int
  amount    Int

  channel   String?
  status    String
  purpose   String?
  createdAt DateTime @default(now())
}

// CHAT SYSTEM
//
model Conversation {
  id                  Int       @id @default(autoincrement())
  productId           Int
  buyerId             Int
  lastMessage         String?
  lastMessageAt       DateTime?
  lastMessageSenderId Int
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  sellerId            Int

  product  Product   @relation(fields: [productId], onDelete: Cascade, references: [id])
  buyer    User      @relation("Buyer", fields: [buyerId], onDelete: Cascade, references: [id])
  seller   User      @relation("Seller", fields: [sellerId], onDelete: Cascade, references: [id])
  messages Message[]

  @@unique([productId, buyerId]) // one chat per buyer per product
  @@index([buyerId])
  @@index([productId])
  @@index([sellerId])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  senderId       Int
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  type           String? // "text" | "image" 
  avatar         String?
  conversation   Conversation @relation(fields: [conversationId], onDelete: Cascade, references: [id])
  sender         User         @relation(fields: [senderId], onDelete: Cascade, references: [id])
}
